<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!--
      debuggable=true is set on purpose for this dev tool:
        1. Allows `adb shell run-as com.oacp.hark.quant_bench` so we can
           push GGUF files directly into the app's private internal
           storage, bypassing the Android 11+ scoped-storage FUSE shim
           that labels adb-pushed files as `media_rw_data_file` (which
           the untrusted_app SELinux domain can't open/stat/readdir).
        2. Allows `adb exec-out run-as ... cat` to pull results files
           from the app's private documents dir for analysis.
      This APK is never shipped. Do not copy this flag to hark-release.
      HardcodedDebugMode lint is suppressed because this is a dev-only
      benchmark harness.
    -->
    <application
        android:label="quant_bench"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:debuggable="true"
        android:extractNativeLibs="true"
        tools:ignore="HardcodedDebugMode,ExtractNativeLibs">
        <!--
          extractNativeLibs=true is REQUIRED for llamadart on Android.

          llamadart's Android bundle ships libggml.so with
          GGML_BACKEND_DL=ON, which means optional backends
          (libggml-vulkan.so, libggml-opencl.so, per-ISA libggml-cpu-*)
          are loaded at runtime by ggml scanning the directory
          containing libggml.so for sibling libggml-*.so files via
          opendir()/readdir().

          With Flutter's default extractNativeLibs=false, all .so files
          live inside base.apk and the Android linker mmap-dlopen's them
          from the zip, so lib/arm64/ is empty on disk and ggml's
          backend scanner finds nothing — every optional backend
          (including Vulkan offload to the Mali/Adreno GPU) silently
          falls back to CPU.

          Setting this to true forces the installer to extract the
          .so files to /data/app/.../lib/arm64/ so ggml can discover
          the Vulkan/CPU-variant plugins via readdir.

          This makes the APK larger and install slightly slower; both
          are fine for a dev-only benchmark harness. If we decide
          llamadart is shipping in hark-release, the same flag is
          needed there too — or we need a custom bundle with backends
          statically linked into libggml.so.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
